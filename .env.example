# =============================================================================
# AstroGuruAI — Environment Configuration
# Copy this file to `.env` and adjust values for your environment.
# =============================================================================

# --- Application ---
APP_NAME=AstroGuruAI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-secret-key

# --- Server ---
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=astroguru
POSTGRES_PASSWORD=astroguru
POSTGRES_DB=astroguru_db
# Optional override (takes precedence over individual POSTGRES_* vars)
# DATABASE_URL=postgresql+asyncpg://astroguru:astroguru@localhost:5432/astroguru_db

# --- Redis (future-ready) ---
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# REDIS_URL=redis://localhost:6379/0

# --- Gemini API (future-ready) ---
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=1.0
GEMINI_RPM_LIMIT=30
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=0.4

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Paths ---
KNOWLEDGEBASE_PATH=knowledgebase
RULE_STUDIO_DATA_PATH=rule_studio_data
CASE_LEARNING_DATA_PATH=case_learning_data
REPORTS_OUTPUT_PATH=reports/generated
PDF_TEMPLATES_PATH=pdf_templates
PROMPTS_PATH=prompts
